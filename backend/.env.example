# Doubao API Configuration
ARK_API_KEY=your_api_key_here
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Model names
LLM_MODEL=doubao-seed-1-8-251228
IMAGE_MODEL=doubao-seedream-4-0-250828

# Volcano TTS Configuration
VOLCANO_ACCESS_KEY=your_volcano_access_key_here
VOLCANO_APP_ID=your_volcano_app_id_here
VOLCANO_CLUSTER=volcano_tts
VOLCANO_VOICE_TYPE=BV700_V2_streaming

# Database
DATABASE_URL=sqlite:///./word_memory.db

# App Settings
APP_NAME=Word Visual Memory
DEBUG=true
